category: "PopDev" 1
{
command: "popdev-kit.runTask"
title: "%command.runTask%"
category: "PopDev" 1
{
command: "popdev-kit.stopTask"
title: "%command.stopTask%"
category: "PopDev" 1
{
command: "popdev-kit.explorer.openInEditor"
title: "%command.explorer.openInEditor%"
category: "PopDev"
icon: "$(go-to-file)" 1
{
command: "popdev-kit.explorer.revealInSidebar"
title: "%command.explorer.revealInSidebar%"
category: "PopDev"
icon: "$(empty-window)" 1
{
command: "popdev-kit.reloadWindow"
title: "%command.reloadWindow%"
category: "PopDev" 1
{
command: "popdev-kit.showLog"
title: "%command.showLog%"
category: "PopDev" 1
{
command: "popdev-kit.getHelp"
title: "%command.getHelp%"
category: "PopDev" 1
{
command: "popdev-kit.getStarted"
title: "%command.getStarted%"
category: "PopDev" 1
{
command: "popdev-kit.provideFeedback"
title: "%command.provideFeedback%"
category: "PopDev" 1
{
command: "popdev-kit.reportIssue"
title: "%command.reportIssue%"
category: "PopDev" 1
{
command: "popdev-kit.explorer.removeProject"
title: "%command.explorer.removeProject%"
category: "PopDev"
icon: "$(close)" 1
{
command: "popdev-kit.explorer.openInCurrentWindow"
title: "%command.explorer.openInCurrentWindow%"
category: "PopDev"
icon: "$(arrow-right)" 1
{
command: "popdev-kit.explorer.openInNewWindow"
title: "%command.explorer.openInNewWindow%"
category: "PopDev"
icon: "$(empty-window)" 1
{
command: "popdev-kit.explorer.setDefault"
