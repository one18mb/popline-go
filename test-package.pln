when: "view == popdevProjects && viewItem =~ /^(config|activeConfig)$/"
group: "2_config@2" 1
{
command: "popdev-kit.explorer.deleteConfig"
when: "view == popdevProjects && viewItem =~ /^(config|activeConfig)$/"
group: "2_config@2" 2
